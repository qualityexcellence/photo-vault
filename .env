# Database
DATABASE_URL=postgresql://photo_user:secure_password@postgres:5432/photo_vault
SQLALCHEMY_ECHO=false

# Google Cloud
GCP_PROJECT_ID=aivaultphotosgcp
GCS_BUCKET_NAME=aivaultphotosgcp-images
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# API
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# AI Models
VISION_AI_MODEL=vision-1.0
VERTEX_AI_ENDPOINT=us-central1-aiplatform.googleapis.com

# Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Debug
DEBUG=true
LOG_LEVEL=INFO